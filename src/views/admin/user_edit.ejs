<div class="page-header"><h1 class="title is-2">Modifier utilisateur #<%= user.id %></h1></div>
<div class="box form-panel" style="max-width:860px;">
  <form method="post" action="/admin/users/<%= user.id %>/update">
    <div class="columns is-multiline">
      <div class="column is-6"><label class="label">Email</label><input class="input" type="email" name="email" required value="<%= old.email %>"></div>
      <div class="column is-6"><label class="label">Nom</label><input class="input" name="full_name" required value="<%= old.full_name || '' %>"></div>
      <div class="column is-4"><label class="label">Rôle</label><div class="select is-fullwidth"><select name="role"><option value="candidate" <%= old.role==='candidate'?'selected':'' %>>Candidat</option><option value="recruiter" <%= old.role==='recruiter'?'selected':'' %>>Recruteur</option><option value="admin" <%= old.role==='admin'?'selected':'' %>>Admin</option></select></div></div>
      <div class="column is-4"><label class="label">Téléphone</label><input class="input" name="phone" value="<%= old.phone || '' %>"></div>
      <div class="column is-4"><label class="label">Actif</label><div class="select is-fullwidth"><select name="is_active"><option value="1" <%= old.is_active ? 'selected' : '' %>>Oui</option><option value="0" <%= !old.is_active ? 'selected' : '' %>>Non</option></select></div></div>
      <div class="column is-12"><label class="label">Présentation</label><textarea class="textarea" name="bio"><%= old.bio || '' %></textarea></div>
      <div class="column is-6"><label class="label">Nouveau mot de passe (optionnel)</label><input class="input" type="password" name="password"></div>
      <div class="column is-12"><button class="button is-primary" type="submit">Enregistrer</button> <a class="button is-light" href="/admin/users">Retour</a></div>
    </div>
  </form>
</div>
