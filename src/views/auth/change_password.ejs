<div class="page-header">
  <h1 class="title is-2">Changer le mot de passe</h1>
</div>

<div class="box form-panel" style="max-width:560px;">
  <form method="post" action="/auth/change-password">
    <div class="field">
      <label class="label">Mot de passe actuel</label>
      <input class="input" type="password" name="current_password" required>
    </div>

    <div class="field">
      <label class="label">Nouveau mot de passe</label>
      <input class="input" type="password" name="new_password" required>
    </div>

    <div class="field">
      <label class="label">Confirmation</label>
      <input class="input" type="password" name="confirm_password" required>
    </div>

    <div class="field mt-5">
      <button class="button is-primary" type="submit">Mettre à jour</button>
      <a class="button is-light" href="/auth/profile">Retour profil</a>
    </div>
  </form>
</div>
