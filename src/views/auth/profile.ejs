<div class="page-header">
  <h1 class="title is-2">Mon profil</h1>
</div>

<div class="box form-panel" style="max-width:760px;">
  <form method="post" action="/auth/profile">
    <div class="columns is-multiline">
      <div class="column is-6">
        <label class="label">Nom complet</label>
        <input class="input" name="full_name" required value="<%= old?.full_name || '' %>">
      </div>

      <div class="column is-6">
        <label class="label">Téléphone</label>
        <input class="input" name="phone" value="<%= old?.phone || '' %>">
      </div>

      <div class="column is-12">
        <label class="label">Présentation</label>
        <textarea class="textarea" name="bio" rows="5"><%= old?.bio || '' %></textarea>
      </div>

      <div class="column is-12">
        <button class="button is-primary" type="submit">Mettre à jour</button>
        <a class="button is-light" href="/auth/change-password">Changer le mot de passe</a>
      </div>
    </div>
  </form>
</div>

<% if (user?.role === "recruiter") { %>
  <div class="box form-panel mt-5" style="max-width:760px;">
    <h2 class="title is-4">Entreprise</h2>
    <% if (!recruiterCompany) { %>
      <div class="empty-state">Aucune entreprise liée à votre compte recruteur.</div>
      <div class="buttons mt-4">
        <a class="button is-primary" href="/recruiter/company">Créer mon entreprise</a>
      </div>
    <% } else { %>
      <div class="content">
        <p><strong>Nom :</strong> <%= recruiterCompany.name %></p>
        <p>
          <strong>Statut :</strong>
          <span class="tag <%= recruiterCompany.is_active ? 'status-active' : 'status-archived' %>">
            <%= recruiterCompany.is_active ? "Active" : "Inactive" %>
          </span>
        </p>
        <p><strong>Site :</strong> <%= recruiterCompany.website || "-" %></p>
        <p><strong>Description :</strong> <%= recruiterCompany.description || "-" %></p>
      </div>
      <div class="buttons mt-4">
        <a class="button is-light" href="/recruiter/company">Modifier mon entreprise</a>
      </div>
    <% } %>
  </div>
<% } %>
