<div class="page-header">
  <h1 class="title is-2">Connexion</h1>
</div>

<div class="box form-panel" style="max-width:560px;">
  <form method="post" action="/auth/login">
    <div class="field">
      <label class="label">Email</label>
      <input class="input" type="email" name="email" required value="<%= old?.email || '' %>">
    </div>

    <div class="field">
      <label class="label">Mot de passe</label>
      <input class="input" type="password" name="password" required>
    </div>

    <div class="field mt-5">
      <button class="button is-primary" type="submit">Se connecter</button>
      <a class="button is-light" href="/auth/register">Créer un compte</a>
    </div>
  </form>
</div>
