<div class="page-header">
  <h1 class="title is-2">Créer une offre</h1>
  <p class="subtitle is-5">Publie une nouvelle opportunité sur le jobboard.</p>
</div>

<div class="columns is-centered">
  <div class="column is-8">
    <div class="box form-panel">
      <% if (flash) { %>
        <article class="message is-<%= flash.type === "success" ? "success" : "danger" %>">
          <div class="message-body"><%= flash.message %></div>
        </article>
      <% } %>

      <form method="post" action="/recruiter/jobs">
        <div class="columns is-multiline">
          <div class="column is-12">
            <div class="field">
              <label class="label">Titre du poste</label>
              <div class="control">
                <input
                  class="input"
                  name="title"
                  value="<%= old.title || "" %>"
                  placeholder="Ex. Développeur Fullstack Node / React"
                  required
                >
              </div>
            </div>
          </div>

          <div class="column is-6">
            <div class="field">
              <label class="label">Lieu</label>
              <div class="control">
                <input
                  class="input"
                  name="location"
                  value="<%= old.location || "" %>"
                  placeholder="Ex. Nice"
                  required
                >
              </div>
            </div>
          </div>

          <div class="column is-6">
            <div class="field">
              <label class="label">Type de contrat</label>
              <div class="control">
                <div class="select is-fullwidth">
                  <select name="contract_type" required>
                    <option value="">Choisir</option>
                    <option value="CDI" <%= old.contract_type === "CDI" ? "selected" : "" %>>CDI</option>
                    <option value="CDD" <%= old.contract_type === "CDD" ? "selected" : "" %>>CDD</option>
                    <option value="Freelance" <%= old.contract_type === "Freelance" ? "selected" : "" %>>Freelance</option>
                    <option value="Stage" <%= old.contract_type === "Stage" ? "selected" : "" %>>Stage</option>
                    <option value="Alternance" <%= old.contract_type === "Alternance" ? "selected" : "" %>>Alternance</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <div class="column is-4">
            <div class="field">
              <label class="label">Télétravail</label>
              <div class="control">
                <div class="select is-fullwidth">
                  <select name="remote">
                    <option value="0" <%= old.remote !== "1" ? "selected" : "" %>>Non</option>
                    <option value="1" <%= old.remote === "1" ? "selected" : "" %>>Oui</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <div class="column is-4">
            <div class="field">
              <label class="label">Salaire min</label>
              <div class="control">
                <input
                  class="input"
                  type="number"
                  name="salary_min"
                  value="<%= old.salary_min || "" %>"
                  placeholder="35000"
                >
              </div>
            </div>
          </div>

          <div class="column is-4">
            <div class="field">
              <label class="label">Salaire max</label>
              <div class="control">
                <input
                  class="input"
                  type="number"
                  name="salary_max"
                  value="<%= old.salary_max || "" %>"
                  placeholder="50000"
                >
              </div>
            </div>
          </div>

          <div class="column is-12">
            <div class="field">
              <label class="label">Description</label>
              <div class="control">
                <textarea
                  class="textarea"
                  name="description"
                  rows="8"
                  placeholder="Décris le poste, les missions, la stack et le profil recherché"
                  required
                ><%= old.description || "" %></textarea>
              </div>
            </div>
          </div>

          <div class="column is-12">
            <div class="buttons">
              <button class="button is-primary" type="submit">Publier l’offre</button>
              <a class="button is-light" href="/recruiter/dashboard">Retour dashboard</a>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>