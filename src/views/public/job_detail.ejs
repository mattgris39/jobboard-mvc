<div class="columns is-variable is-6">
  <div class="column is-7">
    <div class="page-header">
      <h1 class="title is-2"><%= job.title %></h1>
      <p class="subtitle is-6">
        <strong><%= job.company_name %></strong> · <%= job.location %>
        <% if (job.company_website) { %>
          · <a href="<%= job.company_website %>" target="_blank" rel="noreferrer">Site entreprise</a>
        <% } %>
      </p>
    </div>

    <div class="tags mb-4">
      <span class="tag is-light"><%= job.contract_type %></span>
      <% if (job.remote) { %>
        <span class="tag is-info is-light">Télétravail</span>
      <% } %>
      <% if (job.salary_min && job.salary_max) { %>
        <span class="tag is-light"><%= job.salary_min %> - <%= job.salary_max %> €</span>
      <% } %>
    </div>

    <div class="box form-panel">
      <h2 class="title is-5">Description du poste</h2>
      <p style="white-space: pre-line;"><%= job.description %></p>
    </div>

    <div class="mt-5">
      <a class="button is-light" href="/jobs">Retour aux offres</a>
    </div>
  </div>

  <div class="column is-5">
    <div class="box form-panel">
      <h2 class="title is-4">Postuler</h2>

      <form method="post" action="/jobs/<%= job.id %>/apply" enctype="multipart/form-data">
        <div class="field">
          <label class="label">Nom</label>
          <input class="input" name="candidate_name" required value="<%= prefill?.candidate_name || '' %>">
        </div>

        <div class="field">
          <label class="label">Email</label>
          <input class="input" type="email" name="email" required value="<%= prefill?.email || '' %>">
        </div>

        <div class="field">
          <label class="label">Téléphone</label>
          <input class="input" name="phone" value="<%= prefill?.phone || '' %>">
        </div>

        <div class="field">
          <label class="label">Message</label>
          <textarea class="textarea" name="message" rows="5" placeholder="Présente ton profil"><%= prefill?.message || '' %></textarea>
        </div>

        <div class="field">
          <label class="label">CV (PDF)</label>
          <input class="input" type="file" name="cv" accept=".pdf,application/pdf">
          <p class="help">2 Mo max, PDF uniquement.</p>
        </div>

        <button class="button is-primary is-fullwidth" type="submit">Envoyer ma candidature</button>
      </form>
    </div>
  </div>
</div>
