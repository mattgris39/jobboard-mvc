<div class="page-header">
  <h1 class="title is-2">Offres d'emploi</h1>
</div>

<div class="box form-panel">
  <form method="get" action="/jobs">
    <div class="columns is-multiline">
      <div class="column is-4">
        <label class="label">Mot-clé</label>
        <input class="input" name="q" value="<%= filters.q %>" placeholder="Ex. Node, React, pentest">
      </div>

      <div class="column is-3">
        <label class="label">Lieu</label>
        <input class="input" name="location" value="<%= filters.location %>" placeholder="Ex. Paris, télétravail">
      </div>

      <div class="column is-2">
        <label class="label">Contrat</label>
        <div class="select is-fullwidth">
          <select name="contract_type">
            <option value="" <%= !filters.contractType ? "selected" : "" %>>Tous</option>
            <option value="CDI" <%= filters.contractType === "CDI" ? "selected" : "" %>>CDI</option>
            <option value="CDD" <%= filters.contractType === "CDD" ? "selected" : "" %>>CDD</option>
            <option value="Freelance" <%= filters.contractType === "Freelance" ? "selected" : "" %>>Freelance</option>
            <option value="Stage" <%= filters.contractType === "Stage" ? "selected" : "" %>>Stage</option>
            <option value="Alternance" <%= filters.contractType === "Alternance" ? "selected" : "" %>>Alternance</option>
          </select>
        </div>
      </div>

      <div class="column is-1">
        <label class="label">Télétravail</label>
        <div class="select is-fullwidth">
          <select name="remote">
            <option value="all" <%= filters.remote === "all" ? "selected" : "" %>>Tous</option>
            <option value="1" <%= filters.remote === "1" ? "selected" : "" %>>Oui</option>
            <option value="0" <%= filters.remote === "0" ? "selected" : "" %>>Non</option>
          </select>
        </div>
      </div>

      <div class="column is-2">
        <label class="label">Tri date</label>
        <div class="select is-fullwidth">
          <select name="sort">
            <option value="recent" <%= filters.sort === "recent" ? "selected" : "" %>>Récentes</option>
            <option value="oldest" <%= filters.sort === "oldest" ? "selected" : "" %>>Anciennes</option>
          </select>
        </div>
      </div>

      <div class="column is-12 is-flex is-justify-content-space-between is-align-items-center">
        <p class="muted"><strong><%= pagination.total %></strong> résultat(s)</p>
        <div class="buttons">
          <a class="button is-light" href="/jobs">Réinitialiser</a>
          <button class="button is-primary" type="submit">Filtrer</button>
        </div>
      </div>
    </div>
  </form>
</div>

<div class="columns is-variable is-5 mt-5">
  <div class="column is-7">
    <% if (!jobs.length) { %>
      <div class="empty-state">Aucune offre trouvée avec ces filtres.</div>
    <% } else { %>
      <div class="job-list">
        <% jobs.forEach((job) => { %>
          <article class="job-card">
            <div class="job-card-top">
              <div>
                <div class="job-card-title"><%= job.title %></div>
                <div class="job-card-meta"><strong><%= job.company_name %></strong> · <%= job.location %></div>
              </div>
              <div class="job-card-tags">
                <span class="tag is-light"><%= job.contract_type %></span>
                <% if (job.remote) { %><span class="tag is-info is-light">Télétravail</span><% } %>
              </div>
            </div>

            <div class="buttons mt-4">
              <button
                type="button"
                class="button is-primary is-small js-learn-more"
                data-job-id="<%= job.id %>"
                aria-pressed="false"
              >En savoir plus</button>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

    <% if (pagination.totalPages > 1) { %>
      <nav class="pagination is-centered mt-5" role="navigation" aria-label="pagination">
        <%
          const jobPageLink = (pageValue) => {
            const params = new URLSearchParams();
            params.set("q", filters.q || "");
            params.set("location", filters.location || "");
            params.set("contract_type", filters.contractType || "");
            params.set("remote", filters.remote || "all");
            params.set("sort", filters.sort || "recent");
            params.set("page", String(pageValue));
            return `/jobs?${params.toString()}`;
          };
        %>
        <a class="pagination-previous <%= !pagination.hasPrev ? 'is-disabled' : '' %>" <%- pagination.hasPrev ? `href="${jobPageLink(pagination.prevPage)}"` : 'aria-disabled="true" tabindex="-1"' %>>Précédente</a>
        <a class="pagination-next <%= !pagination.hasNext ? 'is-disabled' : '' %>" <%- pagination.hasNext ? `href="${jobPageLink(pagination.nextPage)}"` : 'aria-disabled="true" tabindex="-1"' %>>Suivante</a>
        <ul class="pagination-list">
          <li><span class="pagination-link is-current">Page <%= pagination.page %> / <%= pagination.totalPages %></span></li>
        </ul>
      </nav>
    <% } %>
  </div>

  <div class="column is-5">
    <div id="learn-more-panel" class="box form-panel">
      <h2 class="title is-5">Détail de l'offre</h2>
      <div id="learn-more-content" aria-live="polite"></div>
    </div>
  </div>
</div>

<script src="/static/js/jobs.js"></script>
