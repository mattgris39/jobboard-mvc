<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jobboard MVC</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css">
  <style>
    :root {
      --bg: #0b1220;
      --bg-soft: #111827;
      --card: #0f172a;
      --border: rgba(255, 255, 255, 0.08);
      --text: #f8fafc;
      --muted: #94a3b8;
      --primary: #22d3ee;
      --primary-strong: #06b6d4;
      --link-strong: #0369a1;
      --link-strong-hover: #075985;
    }

    html, body {
      min-height: 100%;
      background:
        radial-gradient(circle at top left, rgba(34, 211, 238, 0.08), transparent 30%),
        linear-gradient(135deg, #050816 0%, #0b1220 45%, #0a1020 100%);
      color: var(--text);
    }

    body {
      font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
    }

    .site-shell {
      min-height: 100vh;
    }

    .site-navbar {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(14px);
      background: rgba(5, 8, 22, 0.78);
      border-bottom: 1px solid var(--border);
    }

    .site-navbar-inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 1rem 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .brand {
      font-size: 1.1rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text);
      text-decoration: none;
    }

    .brand span {
      color: var(--primary);
    }

    .nav-links {
      display: flex;
      gap: 0.65rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .nav-links a {
      color: #dbeafe;
      text-decoration: none;
      padding: 0.55rem 0.9rem;
      border-radius: 999px;
      border: 1px solid transparent;
      transition: 0.2s ease;
    }

    .nav-links a:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: var(--border);
      color: #ffffff;
    }

    .section {
      min-height: calc(100vh - 74px);
      padding-top: 2rem;
      padding-bottom: 3rem;
    }

    .container {
      max-width: 1180px !important;
    }

    .title,
    .subtitle,
    .label,
    .table,
    .table th,
    .table td,
    .content,
    p,
    li,
    strong,
    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      color: var(--text);
    }

    .subtitle,
    .help,
    .muted {
      color: var(--muted) !important;
    }

    a {
      color: var(--link-strong);
      transition: 0.2s ease;
    }

    a:hover {
      color: var(--link-strong-hover);
    }

    .box,
    .message,
    .card,
    .table-container,
    .custom-surface {
      background: rgba(15, 23, 42, 0.78) !important;
      border: 1px solid var(--border);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
      backdrop-filter: blur(10px);
    }

    .input,
    .textarea,
    .select select {
      background: rgba(255, 255, 255, 0.03) !important;
      border-color: var(--border) !important;
      color: var(--text) !important;
      box-shadow: none !important;
    }

    .input::placeholder,
    .textarea::placeholder {
      color: #64748b !important;
    }

    .input:focus,
    .textarea:focus,
    .select select:focus {
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 1px rgba(34, 211, 238, 0.25) !important;
    }

    .button.is-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
      border: none;
      color: #04111d;
      font-weight: 700;
    }

    .button.is-light {
      background: #e2e8f0;
      color: #0f172a;
      border: 1px solid #cbd5e1;
      font-weight: 700;
    }

    .button.is-light:hover {
      background: #f8fafc;
      color: #020617;
      border-color: #94a3b8;
    }

    .button.is-danger.is-light,
    .button.is-warning.is-light {
      font-weight: 700;
    }

    .button.is-danger.is-light {
      background: rgba(220, 38, 38, 0.22);
      color: #fee2e2;
      border-color: rgba(248, 113, 113, 0.5);
    }

    .button.is-danger.is-light:hover {
      background: rgba(220, 38, 38, 0.32);
      color: #ffffff;
      border-color: rgba(248, 113, 113, 0.9);
    }

    .button.is-warning.is-light {
      background: rgba(245, 158, 11, 0.24);
      color: #fffbeb;
      border-color: rgba(245, 158, 11, 0.5);
    }

    .button.is-warning.is-light:hover {
      background: rgba(245, 158, 11, 0.34);
      color: #ffffff;
      border-color: rgba(245, 158, 11, 0.9);
    }

    .button.is-warning {
      background: #f59e0b;
      border-color: #f59e0b;
      color: #111827;
      font-weight: 800;
    }

    .offer-link {
      color: var(--link-strong) !important;
      font-weight: 700;
    }

    .js-learn-more.is-active {
      background: #0369a1 !important;
      color: #e0f2fe !important;
      border-color: #0c4a6e !important;
      box-shadow: 0 0 0 2px rgba(14, 116, 144, 0.35);
    }

    .table {
      background: transparent !important;
    }

    .table thead th {
      color: #e2e8f0 !important;
      border-color: var(--border) !important;
      font-size: 0.92rem;
    }

    .table td {
      border-color: rgba(255, 255, 255, 0.06) !important;
      vertical-align: middle;
    }

    .table-actions {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .table-actions form {
      margin: 0;
    }

    .table.is-striped tbody tr:not(.is-selected):nth-child(even) {
      background: rgba(255, 255, 255, 0.02);
    }

    .tag {
      font-weight: 700;
      border-radius: 999px;
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }

    .tag.is-light {
      background: #e2e8f0 !important;
      color: #0f172a !important;
      border: 1px solid #cbd5e1;
    }

    .tag.is-info {
      background: #0ea5e9 !important;
      color: #f8fafc !important;
    }

    .tag.is-warning {
      background: #f59e0b !important;
      color: #111827 !important;
    }

    .tag.is-success {
      background: #16a34a !important;
      color: #f8fafc !important;
    }

    .tag.is-danger {
      background: #dc2626 !important;
      color: #f8fafc !important;
    }

    .tag.role-admin {
      background: #7c3aed !important;
      color: #f5f3ff !important;
    }

    .tag.role-recruiter {
      background: #0f766e !important;
      color: #ecfeff !important;
    }

    .tag.role-candidate {
      background: #1d4ed8 !important;
      color: #eff6ff !important;
    }

    .tag.status-active {
      background: #15803d !important;
      color: #f0fdf4 !important;
    }

    .tag.status-archived {
      background: #475569 !important;
      color: #f8fafc !important;
    }

    .page-header {
      margin-bottom: 1.5rem;
    }

    .pagination .is-disabled {
      opacity: 0.45;
      pointer-events: none;
      cursor: not-allowed;
    }

    .hero-panel {
      padding: 2rem;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(17, 28, 49, 0.8));
      border: 1px solid var(--border);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    }

    .hero-actions {
      display: flex;
      gap: 0.85rem;
      flex-wrap: wrap;
      margin-top: 1.25rem;
    }

    .job-list {
      display: grid;
      gap: 1rem;
      margin-top: 1.25rem;
    }

    .job-card {
      display: block;
      padding: 1.1rem 1.2rem;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(15, 23, 42, 0.75);
      text-decoration: none;
      transition: 0.2s ease;
    }

    .job-card:hover {
      transform: translateY(-2px);
      border-color: rgba(34, 211, 238, 0.35);
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.24);
    }

    .job-card-top {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .job-card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.3rem;
    }

    .job-card-meta {
      color: var(--muted);
      font-size: 0.98rem;
    }

    .job-card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.85rem;
    }

    .empty-state {
      padding: 1rem 1.1rem;
      border-radius: 14px;
      border: 1px solid rgba(245, 158, 11, 0.18);
      background: rgba(245, 158, 11, 0.14);
      color: #fde68a;
    }

    .form-panel {
      border-radius: 18px;
      padding: 1.25rem;
    }

    .company-summary {
      display: grid;
      gap: 0.5rem;
    }

    .company-summary p {
      margin-bottom: 0;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .stat-card {
      padding: 1.25rem;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(15, 23, 42, 0.72);
    }

    .stat-label {
      color: var(--muted);
      font-size: 0.95rem;
      margin-bottom: 0.4rem;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--text);
    }

    .mt-5 {
      margin-top: 1.5rem !important;
    }

    .mt-6 {
      margin-top: 2rem !important;
    }

    @media (max-width: 768px) {
      .section {
        padding-top: 1.3rem;
      }

      .site-navbar-inner {
        align-items: flex-start;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .table-container {
        overflow-x: auto;
      }
    }
  </style>
</head>
<body>
  <div class="site-shell">
    <header class="site-navbar">
      <div class="site-navbar-inner">
        <a class="brand" href="/">
          Jobboard<span>MVC</span>
        </a>

        <nav class="nav-links">
          <a href="/">Accueil</a>
          <a href="/jobs">Offres</a>

          <% if (user?.role === "candidate") { %>
            <a href="/candidate/dashboard">Tableau de bord candidat</a>
          <% } %>

          <% if (user?.role === "recruiter") { %>
            <a href="/recruiter/dashboard">Tableau de bord recruteur</a>
            <a href="/recruiter/company">Mon entreprise</a>
          <% } %>

          <% if (user?.role === "admin") { %>
            <a href="/admin/dashboard">Tableau de bord admin</a>
            <a href="/admin/users">Utilisateurs</a>
            <a href="/admin/companies">Entreprises</a>
            <a href="/admin/jobs">Offres</a>
            <a href="/admin/applications">Candidatures</a>
          <% } %>

          <% if (!user) { %>
            <a href="/auth/register">Inscription</a>
            <a href="/auth/login">Connexion</a>
          <% } else { %>
            <a href="/auth/profile">Mon profil</a>
            <form method="post" action="/auth/logout" style="display:inline;">
              <button type="submit" class="button is-light">Déconnexion</button>
            </form>
          <% } %>
        </nav>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <% if (flash) { %>
          <article class="message is-<%= flash.type %>">
            <div class="message-body"><%= flash.message %></div>
          </article>
        <% } %>
        <%- body %>
      </div>
    </section>
  </div>
</body>
</html>
