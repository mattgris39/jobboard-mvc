<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jobboard MVC</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css">

  <style>
    :root {
      --bg: #0b1220;
      --bg-soft: #111827;
      --card: #0f172a;
      --card-2: #111c31;
      --border: rgba(255,255,255,0.08);
      --text: #f8fafc;
      --muted: #94a3b8;
      --primary: #22d3ee;
      --primary-strong: #06b6d4;
      --success: #22c55e;
      --warning: #f59e0b;
      --danger: #ef4444;
    }

    html, body {
      min-height: 100%;
      background:
        radial-gradient(circle at top left, rgba(34, 211, 238, 0.08), transparent 30%),
        linear-gradient(135deg, #050816 0%, #0b1220 45%, #0a1020 100%);
      color: var(--text);
    }

    body {
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .site-shell {
      min-height: 100vh;
    }

    .site-navbar {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(14px);
      background: rgba(5, 8, 22, 0.78);
      border-bottom: 1px solid var(--border);
    }

    .site-navbar-inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 1rem 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .brand {
      font-size: 1.1rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text);
      text-decoration: none;
    }

    .brand span {
      color: var(--primary);
    }

    .nav-links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .nav-links a {
      color: #dbeafe;
      text-decoration: none;
      padding: 0.65rem 0.95rem;
      border-radius: 999px;
      border: 1px solid transparent;
      transition: 0.2s ease;
    }

    .nav-links a:hover {
      background: rgba(255,255,255,0.06);
      border-color: var(--border);
      color: #ffffff;
    }

    .section {
      min-height: calc(100vh - 74px);
      padding-top: 2.2rem;
      padding-bottom: 3rem;
    }

    .container {
      max-width: 1180px !important;
    }

    .title,
    .subtitle,
    .label,
    .table,
    .table th,
    .table td,
    .content,
    p,
    li,
    strong,
    span,
    a,
    h1, h2, h3, h4, h5, h6 {
      color: var(--text);
    }

    .subtitle,
    .help,
    .muted,
    .table td.is-muted {
      color: var(--muted) !important;
    }

    a {
      color: #7dd3fc;
      transition: 0.2s ease;
    }

    a:hover {
      color: #bae6fd;
    }

    .box,
    .message,
    .card,
    .panel,
    .table-container,
    .custom-surface {
      background: rgba(15, 23, 42, 0.78) !important;
      border: 1px solid var(--border);
      box-shadow: 0 10px 30px rgba(0,0,0,0.22);
      backdrop-filter: blur(10px);
    }

    .input,
    .textarea,
    .select select {
      background: rgba(255,255,255,0.03) !important;
      border-color: var(--border) !important;
      color: var(--text) !important;
      box-shadow: none !important;
    }

    .input::placeholder,
    .textarea::placeholder {
      color: #64748b !important;
    }

    .input:focus,
    .textarea:focus,
    .select select:focus {
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 1px rgba(34, 211, 238, 0.25) !important;
    }

    .button.is-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
      border: none;
      color: #04111d;
      font-weight: 700;
    }

    .button.is-primary:hover {
      filter: brightness(1.05);
      transform: translateY(-1px);
    }

    .button {
      transition: 0.2s ease;
    }

    .button.is-light {
      background: rgba(255,255,255,0.08);
      color: var(--text);
      border: 1px solid var(--border);
    }

    .button.is-light:hover {
      background: rgba(255,255,255,0.12);
    }

    .table {
      background: transparent !important;
    }

    .table thead th {
      color: #e2e8f0 !important;
      border-color: var(--border) !important;
      font-size: 0.92rem;
    }

    .table td {
      border-color: rgba(255,255,255,0.06) !important;
      vertical-align: top;
    }

    .table.is-striped tbody tr:not(.is-selected):nth-child(even) {
      background: rgba(255,255,255,0.02);
    }

    .tag {
      font-weight: 700;
      border-radius: 999px;
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }

    .page-header {
      margin-bottom: 2rem;
    }

    .page-header .title {
      margin-bottom: 0.35rem !important;
    }

    .hero-panel {
      padding: 2rem;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(17, 28, 49, 0.8));
      border: 1px solid var(--border);
      box-shadow: 0 18px 40px rgba(0,0,0,0.28);
    }

    .hero-actions {
      display: flex;
      gap: 0.85rem;
      flex-wrap: wrap;
      margin-top: 1.25rem;
    }

    .job-list {
      display: grid;
      gap: 1rem;
      margin-top: 1.25rem;
    }

    .job-card {
      display: block;
      padding: 1.1rem 1.2rem;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(15, 23, 42, 0.75);
      text-decoration: none;
      transition: 0.2s ease;
    }

    .job-card:hover {
      transform: translateY(-2px);
      border-color: rgba(34, 211, 238, 0.35);
      box-shadow: 0 14px 32px rgba(0,0,0,0.24);
    }

    .job-card-top {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .job-card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.3rem;
    }

    .job-card-meta {
      color: var(--muted);
      font-size: 0.98rem;
    }

    .job-card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.85rem;
    }

    .dashboard-table td.message-cell {
      max-width: 260px;
      white-space: normal;
      word-break: break-word;
      color: #e2e8f0;
    }

    .dashboard-table td,
    .dashboard-table th {
      text-align: left;
    }

    .dashboard-table td.cv-cell a,
    .dashboard-table td.mail-cell a {
      white-space: nowrap;
    }

    .detail-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin-top: 1rem;
      margin-bottom: 1rem;
    }

    .detail-description {
      line-height: 1.7;
      white-space: pre-line;
      color: #dbeafe;
    }

    .empty-state {
      padding: 1rem 1.1rem;
      border-radius: 14px;
      border: 1px solid rgba(245, 158, 11, 0.18);
      background: rgba(245, 158, 11, 0.14);
      color: #fde68a;
    }

    .form-panel {
      border-radius: 18px;
      padding: 1.25rem;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }

    .stat-card {
      padding: 1.25rem;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(15, 23, 42, 0.72);
    }

    .stat-label {
      color: var(--muted);
      font-size: 0.95rem;
      margin-bottom: 0.4rem;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--text);
    }

    @media (max-width: 768px) {
      .section {
        padding-top: 1.5rem;
      }

      .job-card-top {
        flex-direction: column;
      }

      .table-container {
        overflow-x: auto;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .site-navbar-inner {
        align-items: flex-start;
      }

      .select select {
        background: rgba(255,255,255,0.03) !important;
        color: var(--text) !important;
        border-color: var(--border) !important;
      }           

      .field.has-addons .control .button,
      .field.has-addons .control .select select {
        height: 2.2rem;
      }

      .dashboard-stats {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      .dashboard-stats .stat-card {
        position: relative;
        overflow: hidden;
      }

      .dashboard-stats .stat-card::after {
        content: "";
        position: absolute;
        inset: auto -20% -35% auto;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(34, 211, 238, 0.16), transparent 70%);
        pointer-events: none;
      }

      .mt-5 {
        margin-top: 1.5rem !important;
      }

      .mt-6 {
        margin-top: 2rem !important;
      }

    @media (max-width: 1024px) {
      .dashboard-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
       }
      }

    @media (max-width: 640px) {
      .dashboard-stats {
        grid-template-columns: 1fr;
       }
      }
      .dashboard-header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.dashboard-filter-grid {
  align-items: stretch;
}

.dashboard-filter-field {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.dashboard-hidden-label {
  visibility: hidden;
}

.dashboard-filter-button {
  min-height: 3rem;
}

.dashboard-filter-field .control,
.dashboard-filter-field .control .button {
  height: 100%;
}

.dashboard-filter-field .button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.dashboard-status-form {
  margin: 0;
}

.dashboard-status-form .field.has-addons {
  align-items: center;
}

.dashboard-table td,
.dashboard-table th {
  vertical-align: middle;
}

@media (max-width: 768px) {
  .dashboard-header-bar {
    align-items: flex-start;
  }
}

.salary-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  padding: 0.45rem 0.95rem;
  border-radius: 999px;
  background: rgba(148, 163, 184, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.10);
  color: #f8fafc;
  font-size: 0.88rem;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}
}
  </style>
</head>
<body>
  <div class="site-shell">
    <header class="site-navbar">
      <div class="site-navbar-inner">
        <a class="brand" href="/">
          Jobboard<span>MVC</span>
        </a>

        <nav class="nav-links">
          <a href="/">Accueil</a>
          <a href="/jobs">Offres</a>
          <a href="/recruiter/dashboard">Dashboard recruteur</a>
        </nav>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <%- body %>
      </div>
    </section>
  </div>
</body>
</html>